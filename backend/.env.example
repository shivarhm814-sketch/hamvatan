NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Ports 5433/6380 (not the 5432/6379 defaults) to avoid clashing with any other project's
# Postgres/Redis containers you might already have running locally — see docker-compose.yml.
DATABASE_URL=postgresql://esmaeili:pass@localhost:5433/esmaeili_platform?schema=public

REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

JWT_SECRET=change-me-minimum-32-characters-long
JWT_EXPIRES_IN=7d

OTP_LENGTH=5
OTP_TTL_SECONDS=120
OTP_MAX_ATTEMPTS=5

SMS_PROVIDER=mock
SMS_API_KEY=
SMS_SENDER_LINE=

THROTTLE_TTL=60
THROTTLE_LIMIT=10

CORS_ORIGIN=http://localhost:3002

# Optional: mobile number to bootstrap as the first ADMIN user when running `npx prisma db seed`.
# Log in with OTP using this number afterwards to access /admin.
ADMIN_MOBILE=

# STORAGE_PROVIDER=local saves uploads to a folder on this machine's disk (STORAGE_LOCAL_DIR)
# instead of real cloud storage — use this for local testing until real Arvan Cloud
# credentials below are filled in, then switch back to STORAGE_PROVIDER=s3.
STORAGE_PROVIDER=s3
STORAGE_LOCAL_DIR=uploads
STORAGE_BUCKET=esmaeili-dev
STORAGE_REGION=default
STORAGE_ENDPOINT=https://s3.ir-thr-at1.arvanstorage.ir
STORAGE_ACCESS_KEY_ID=your-key
STORAGE_SECRET_ACCESS_KEY=your-secret
STORAGE_PUBLIC_BASE_URL=https://esmaeili-dev.s3.ir-thr-at1.arvanstorage.ir

SENTRY_DSN=
